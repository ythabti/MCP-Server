# Google Gemini API key — 100% free, no credit card needed
# Get one in 30 seconds at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# NewsAPI.org key — free tier at https://newsapi.org (100 req/day)
# Leave empty to use only Hacker News (which is always free)
NEWS_API_KEY=your_newsapi_key

# Resend API key — free tier at https://resend.com
RESEND_API_KEY=your_resend_api_key

# Where to send the daily report
RECIPIENT_EMAIL=you@example.com

# Sender address — must match a verified domain in Resend
# For testing you can use the default: onboarding@resend.dev (sends to your Resend account email only)
EMAIL_FROM=IT News Agent <onboarding@resend.dev>

# When to send the daily report (cron format, default: 8 AM every day)
SEND_TIME=0 8 * * *
